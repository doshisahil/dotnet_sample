{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "IncludeScopes": false,
      "TimestampFormat": "yyyy-MM-dd HH:mm:ss "
    }
  },
  "SampleSettings": {
    "ApplicationName": ".NET Core Features Sample",
    "Version": "1.0.0",
    "Features": {
      "EnableFileWatcher": true,
      "EnableWebSocket": true,
      "WatchDirectory": "./watch",
      "WebSocketPort": 8080
    }
  },
  "ServerApi": {
    "BaseUrl": "https://localhost:7000",
    "Username": "demo",
    "Password": "Demo123!"
  },
  "Resilience": {
    "RetryPolicy": {
      "MaxAttempts": 3,
      "DelayInSeconds": 1
    },
    "CircuitBreaker": {
      "FailureThreshold": 5,
      "RecoveryTimeInSeconds": 30
    }
  }
}